# Apple Push Notification / APNs
host-suffix, push.apple.com, Apple Proxy
host-suffix, sandbox.push.apple.com, Apple Proxy
host-suffix, api.push.apple.com, Apple Proxy
host-suffix, gateway.push.apple.com, Apple Proxy

# Apple Intelligence / Siri / Search / Private Cloud Compute
host, guzzoni.apple.com, Apple Proxy
host-suffix, smoot.apple.com, Apple Proxy
host, apple-relay.cloudflare.com, Apple Proxy
host, apple-relay.fastly-edge.com, Apple Proxy
host, cp4.cloudflare.com, Apple Proxy
host, apple-relay.apple.com, Apple Proxy
host-suffix, siri.apple.com, Apple Proxy
host-suffix, gspe1-ssl.ls.apple.com, Apple Proxy

# Optional: iCloud Private Relay
host, mask.icloud.com, Apple Proxy
host, mask-h2.icloud.com, Apple Proxy
host, mask-api.icloud.com, Apple Proxy

